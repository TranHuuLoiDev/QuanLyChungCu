<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarNoti"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#2196F3"
        app:title="Soạn Thông Báo Mới"
        app:titleTextColor="#FFFFFF" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tiêu đề thông báo:"
            android:textStyle="bold"
            android:textColor="#333333"/>

        <EditText
            android:id="@+id/edtNotiTitle"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:background="@android:drawable/editbox_background"
            android:hint="Nhập tiêu đề (VD: Lịch cắt điện...)"
            android:padding="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Nội dung chi tiết:"
            android:textStyle="bold"
            android:textColor="#333333"/>

        <EditText
            android:id="@+id/edtNotiContent"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="8dp"
            android:background="@android:drawable/editbox_background"
            android:gravity="top|start"
            android:hint="Nhập nội dung chi tiết gửi đến cư dân..."
            android:inputType="textMultiLine"
            android:padding="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Loại thông báo:"
            android:textStyle="bold"
            android:textColor="#333333"/>

        <RadioGroup
            android:id="@+id/rgNotiType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbNormal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="Thông thường (Màu xanh)" />

            <RadioButton
                android:id="@+id/rbUrgent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:buttonTint="#D32F2F"
                android:text="Khẩn cấp (Màu đỏ)" />
        </RadioGroup>

        <Button
            android:id="@+id/btnSendNoti"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="32dp"
            android:backgroundTint="#4CAF50"
            android:text="GỬI THÔNG BÁO CHO TOÀN BỘ CƯ DÂN"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>