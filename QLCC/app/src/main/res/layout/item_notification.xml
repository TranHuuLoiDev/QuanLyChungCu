<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvNotiTypeAndDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔴 Khẩn cấp • 13/04/2026 08:00"
            android:textColor="#D32F2F"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNotiTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="TIÊU ĐỀ THÔNG BÁO"
            android:textColor="#333333"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvNotiContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Nội dung chi tiết của thông báo sẽ hiển thị ở đây..."
            android:textColor="#666666" />
    </LinearLayout>
</androidx.cardview.widget.CardView>